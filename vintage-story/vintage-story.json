{
  "type": "custom",
  "display": "Vintage Story Server",
  "data": {
    "maxPlayers": {
      "type": "integer",
      "value": 16,
      "display": "Max Players",
      "desc": "Maximum number of players that can join the server",
      "required": true,
      "userEdit": true
    },
    "port": {
      "type": "integer",
      "value": 42420,
      "display": "Port",
      "desc": "Port used to connect to the server",
      "required": true,
      "userEdit": false
    },
    "version": {
      "type": "string",
      "value": "1.20.10",
      "display": "version",
      "desc": "Version of Vintage Story to install (e.g., 1.20.10), you can find the latest version here: https://account.vintagestory.at/downloads",
      "required": true,
      "userEdit": true
    },
    "dotnetversion": {
      "type": "string",
      "value": "8.0.15",
      "display": ".NET Runtime Version",
      "desc": ".NET Runtime Version",
      "required": true,
      "userEdit": false
    }
  },
  "install": [
    {
      "if": "env == 'host'",
      "type": "download",
      "files": [
        "https://dotnetcli.azureedge.net/dotnet/Runtime/${dotnetversion}/dotnet-runtime-${dotnetversion}-linux-x64.tar.gz"
      ]
    },
    {
      "if": "env == 'host'",
      "type": "command",
      "commands": [
        "rm -rf dotnet",
        "mkdir -p dotnet"
      ]
    },
    {
      "if": "env == 'host'",
      "type": "extract",
      "source": "dotnet-runtime-${dotnetversion}-linux-x64.tar.gz",
      "destination": "dotnet"
    },
    {
      "if": "env == 'host'",
      "type": "command",
      "commands": [
        "rm -rf dotnet-runtime-${dotnetversion}-linux-x64.tar.gz"
      ]
    },
    {
      "type": "download",
      "files": [
        "https://cdn.vintagestory.at/gamefiles/stable/vs_server_linux-x64_${version}.tar.gz"
      ]
    },
    {
      "type": "mkdir",
      "target": "data"
    },
    {
      "type": "command",
      "commands": [
        "tar -xzf vs_server_linux-x64_${version}.tar.gz"
      ]
    },
    {
      "type": "writefile",
      "target": "VintagestoryServer.runtimeconfig.json",
      "text": "{\n  \"runtimeOptions\": {\n    \"tfm\": \"net8.0\",\n    \"framework\": {\n      \"name\": \"Microsoft.NETCore.App\",\n      \"version\": \"8.0.15\"\n    },\n    \"configProperties\": {\n      \"System.Reflection.Metadata.MetadataUpdater.IsSupported\": false,\n      \"System.Runtime.TieredPGO\": true\n    }\n  }\n}"
    }
  ],
  "run": {
    "command": [
      {
        "command": "./dotnet/dotnet VintagestoryServer.dll --dataPath ./data --port ${port} --maxclients ${maxPlayers}",
        "if": "env == 'host'"
      },
      {
        "command": "dotnet VintagestoryServer.dll --dataPath ./data --port ${port} --maxclients ${maxPlayers}"
      }
    ],
    "stop": "/stop",
    "environmentVars": {
      "DOTNET_ROOT": "./dotnet"
    }
  },
  "environment": {
    "type": "host"
  },
  "supportedEnvironments": [
    {
      "type": "host"
    },
    {
      "type": "docker",
      "image": "mcr.microsoft.com/dotnet/runtime:${dotnetversion}",
      "portBindings": [
        "0.0.0.0:${port}:${port}/tcp"
      ]
    }
  ],
  "requirements": {
    "arch": "amd64"
  }
}
