{
  "display": "Counter Strike 1.6",
  "type": "goldsrc",
  "data": {
    "ip": {
      "type": "string",
      "desc": "What IP to bind the server to",
      "display": "IP",
      "required": true,
      "value": "0.0.0.0"
    },
    "loadMap": {
      "type": "string",
      "desc": "Map to load by default",
      "display": "Map",
      "required": true,
      "value": "de_dust2"
    },
    "maxplayers": {
      "type": "integer",
      "desc": "Max players allowed on server",
      "display": "Max Players",
      "required": true,
      "value": 20
    },
    "tickrate": {
      "type": "integer",
      "desc": "Server tick speed, to use this value you need to download this addon: https://github.com/daemon32/tickrate_enabler/releases/tag/0.5",
      "display": "Tickrate",
      "required": true,
      "value": 66
    },
    "tvport": {
      "type": "integer",
      "desc": "What port to bind the HLTV to",
      "display": "HLTV Port",
      "required": true,
      "value": 27020
    }
  },
  "install": [
    {
      "if": "env == 'host'",
      "type": "steamgamedl",
      "appId": "90"
    },
    {
      "if": "env == 'docker'",
      "type": "command",
      "commands": [
        "steamcmd +force_install_dir /pufferpanel +login anonymous +app_update 90 +quit"
      ]
    }
  ],
  "run": {
    "stop": "exit",
    "command": "./hlds_run -game cstrike -ip ${ip} -port 27015 +clientport 27005 +tv_port 27020 +map ${loadMap} -maxplayers ${maxplayers} -tickrate ${tickrate} -norestart",
    "pre": [],
    "post": [],
    "environmentVars": {}
  },
  "environment": {
    "type": "host"
  },
  "supportedEnvironments": [
    {
      "type": "host"
    },
    {
      "type": "docker",
      "image": "steamcmd/steamcmd",
      "portBindings": [
        "0.0.0.0:27015:27015/tcp",
        "0.0.0.0:27005:27005/tcp",
        "0.0.0.0:27020:27020/tcp"
      ]
    }
  ],
  "requirements": {
    "os": "linux",
    "arch": "amd64"
  }
}
